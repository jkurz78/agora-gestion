APP_NAME="AgoraGestion (Démo)"
APP_ENV=demo
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Europe/Paris
APP_URL=https://demo.agoragestion.org

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

LOG_CHANNEL=stack
LOG_LEVEL=info
LOG_DEPRECATIONS_CHANNEL=null

# Base de données démo dédiée (DIFFÉRENTE de la prod)
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=CHANGER_MOI_NOM_DB_DEMO
DB_USERNAME=CHANGER_MOI_USER_DEMO
DB_PASSWORD=CHANGER_MOI_MOT_DE_PASSE

# Sessions en DB (cohérent avec la prod, sera purgé à chaque reset)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

# Cache et queues — sync suffit en démo (pas de jobs lourds après bridage)
CACHE_STORE=database
QUEUE_CONNECTION=sync

# Mails routés vers le log (jamais d'envoi externe en démo)
MAIL_MAILER=log
MAIL_FROM_ADDRESS="demo@agoragestion.org"
MAIL_FROM_NAME="${APP_NAME}"

# HelloAsso, IMAP, OCR : bridés au runtime via App\Support\Demo::isActive()
# Les clés ci-dessous sont des placeholders — laisser vides ou avec valeurs factices
HELLOASSO_CLIENT_ID=
HELLOASSO_CLIENT_SECRET=
HELLOASSO_ENVIRONMENT=sandbox

ANTHROPIC_API_KEY=

# Filesystem
FILESYSTEM_DISK=local

# Broadcasting (non utilisé en démo)
BROADCAST_CONNECTION=log
